# YouTube API key from Google Cloud
YOUTUBE_API_KEY=

# Your YouTube channel ID.
# Optional if YOUTUBE_HANDLE is set, but recommended.
YOUTUBE_CHANNEL_ID=

# Your YouTube handle without @
YOUTUBE_HANDLE=FlashDust

# Twitch API credentials from https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_CHANNEL=flashdustwastaken
